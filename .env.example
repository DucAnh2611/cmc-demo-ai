# Entra ID
NEXT_PUBLIC_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_API_AUDIENCE=api://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=xxx
AZURE_SEARCH_INDEX_NAME=secure-docs-index

# Azure OpenAI (embeddings)
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-6

# Demo group IDs (fill after creating groups in Entra)
GROUP_HR_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GROUP_FINANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GROUP_PUBLIC_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: gate /api/upload to members of this group (e.g. only the
# `upload` account publishes documents). When unset, any authenticated
# user can upload — useful for local dev. The per-group ACL check
# (uploader can only share with groups they belong to) always applies.
GROUP_UPLOADERS_ID=

# Azure Blob Storage (uploads — file references for /api/upload)
# Connection string from portal: Storage account → Security + networking → Access keys → key1 → Connection string
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=uploads

# Optional: Application Insights audit log
APPLICATIONINSIGHTS_CONNECTION_STRING=
